{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "raiholdings",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-03-01",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "services": [
    { "binding": "WORKER_SELF_REFERENCE", "service": "raiholdings" }
  ],
  "observability": { "enabled": true },
  "//note": "Non-secret config baked here so it survives every deploy. SECRETS (RAISOCIAL_SERVER_KEY, RAISOCIAL_APP_SECRET, SESSION_SECRET, RAICRM_TOKEN, ADMIN_PASSWORD, RAI_LLMS_ADMIN_TOKEN) must be set as Secrets in the dashboard or via `wrangler secret put` — never put secrets here.",
  "vars": {
    "RAISOCIAL_BASE": "https://raisocial.vn/api",
    "RAISOCIAL_SITE": "https://raisocial.vn",
    "RAISOCIAL_APP_ID": "92b9ed98f5fc8b545cf7",
    "RAICRM_BASE": "https://raicrm.vn/api",
    "SUPABASE_URL": "https://api.raiholdings.vn",
    "RAI_LLMS_BASE": "https://llms.raiholdings.vn/api/v1",
    "RAI_LLMS_MODEL": "anthropic/claude-opus-4.8"
  }
}
