{
  "name": "rai-llms-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "RAI LLMs — self-hosted LLM gateway (OpenAI-compatible). Deploy on your own VPS.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "migrate": "node --import tsx scripts/migrate.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "fastify": "^5.2.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
