# RAI LLMs Gateway — copy to .env and fill. NEVER commit .env.
PORT=8080
NODE_ENV=production

# Postgres (data model in sql/schema.sql)
DATABASE_URL=postgres://rai:CHANGE_ME@localhost:5432/rai_llms

# Redis (rate limit / cache) — optional; gateway degrades gracefully if unset
REDIS_URL=

# 32-byte key (hex or base64) for AES-256-GCM encryption of upstream/BYOK keys.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS

# Master admin token for /admin endpoints (Bearer)
ADMIN_TOKEN=CHANGE_ME

# Billing
FX_USD_VND=25400          # credits are stored in VND
DEFAULT_MARKUP_PERCENT=20 # platform markup on upstream price (overridable per model/provider)

# Upstream provider API keys (server-side ONLY — encrypted at rest in DB in prod).
# These env values are a bootstrap fallback for local dev.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
