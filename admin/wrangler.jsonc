{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "rai-admin",
  "compatibility_date": "2025-03-01",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    { "pattern": "admin.raiholdings.vn", "custom_domain": true }
  ]
}
