{
  "manifest_version": 3,
  "name": "RAI OS",
  "version": "1.4.0",
  "description": "Truy cập nhanh RAI OS — tạo Venture, tra cứu doanh nghiệp, lưu trang vào RAI.",
  "default_locale": "vi",
  "action": {
    "default_popup": "popup.html",
    "default_title": "RAI OS",
    "default_icon": { "16": "icons/icon-16.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" }
  },
  "permissions": ["storage", "activeTab", "scripting", "contextMenus", "notifications"],
  "host_permissions": ["https://*.raiholdings.vn/*"],
  "icons": { "16": "icons/icon-16.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" },
  "options_ui": { "page": "options.html", "open_in_tab": true }
}
