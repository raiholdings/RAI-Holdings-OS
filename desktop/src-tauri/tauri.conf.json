{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RAI OS",
  "version": "1.4.0",
  "identifier": "vn.raiholdings.os",
  "build": {
    "frontendDist": "../shell",
    "devUrl": "https://workspace.raiholdings.vn"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "RAI OS",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "dmg", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "RAI Holdings",
    "category": "Business",
    "shortDescription": "Hệ điều hành doanh nghiệp AI-Native",
    "longDescription": "RAI OS — gõ một ý tưởng, RAI dựng nên công ty. Venture Builder, Big Data, RAI LLMs và 8 engine tự động."
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://update.raiholdings.vn/{{target}}/{{arch}}/{{current_version}}"
      ],
      "pubkey": "PUT_TAURI_UPDATER_PUBLIC_KEY_HERE"
    }
  }
}
