# RAI OS mobile — fastlane lanes. Native projects (android/, ios/) are generated by
# `npx cap sync` in CI before these run. Credentials come from env (GitHub Secrets).

platform :android do
  desc "Build signed AAB and upload to Google Play (internal track)"
  lane :release do
    gradle(project_dir: "android", task: "bundle", build_type: "Release")
    upload_to_play_store(
      track: "internal",
      aab: "android/app/build/outputs/bundle/release/app-release.aab",
      json_key_data: ENV["PLAY_SERVICE_ACCOUNT_JSON"],
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end
end

platform :ios do
  desc "Build IPA and upload to TestFlight"
  lane :release do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_P8_BASE64"],
      is_key_content_base64: true
    )
    build_app(workspace: "ios/App/App.xcworkspace", scheme: "App", export_method: "app-store")
    upload_to_testflight(api_key: api_key, skip_waiting_for_build_processing: true)
  end
end
